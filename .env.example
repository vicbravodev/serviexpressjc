# Supabase (leads + panel admin)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Meta Conversions API (server-side)
# Token de acceso: Events Manager > Orígenes de datos > tu pixel > Configuración >
# "API de conversiones" > Generar token de acceso. Es secreto: NO lo subas al repo.
META_CAPI_ACCESS_TOKEN=
# Opcional. Sólo para pruebas: Events Manager > Probar eventos ("Test Events").
# Déjalo vacío en producción.
META_TEST_EVENT_CODE=
# Opcionales (tienen valor por defecto):
# META_PIXEL_ID=1359979335628376
# META_GRAPH_VERSION=v21.0
